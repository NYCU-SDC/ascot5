+static inline void interp3Dcomp_eval_df4_precomputed(real* f_df,
+                                                      const real* c,
+                                                      int n, int x1, int y1,
+                                                      int z1,
+                                                      real dxi, real dx,
+                                                      real dxi3, real dx3,
